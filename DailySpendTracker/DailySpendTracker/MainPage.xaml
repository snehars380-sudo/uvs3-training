<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DailySpendTracker.MainPage">

    <VerticalStackLayout Padding="20" Spacing="10">

        <!-- HEADER -->
        <Label Text="💰 Daily Spend Tracker PRO"
               FontSize="26"
               HorizontalOptions="Center"/>

        <!-- DASHBOARD -->
        <Frame BackgroundColor="LightGray" Padding="10">
            <VerticalStackLayout>
                <Label x:Name="totalLabel" Text="Total: 0" FontSize="18"/>
                <Label x:Name="countLabel" Text="Expenses: 0" FontSize="14"/>
            </VerticalStackLayout>
        </Frame>

        <!-- INPUT -->
        <Entry x:Name="titleEntry" Placeholder="Expense Title"/>

        <Entry x:Name="amountEntry"
               Placeholder="Amount"
               Keyboard="Numeric"/>

        <!-- CATEGORY -->
        <Picker x:Name="categoryPicker" Title="Category">
            <Picker.Items>
                <x:String>Food</x:String>
                <x:String>Travel</x:String>
                <x:String>Shopping</x:String>
                <x:String>Bills</x:String>
                <x:String>Other</x:String>
            </Picker.Items>
        </Picker>

        <Button Text="Add / Update Expense"
                Clicked="OnAddClicked"/>

        <!-- LIST -->
        <CollectionView x:Name="expenseList">

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <SwipeView>

                        <!-- DELETE -->
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="Delete"
                                           BackgroundColor="Red"
                                           CommandParameter="{Binding .}"
                                           Invoked="OnDeleteSwipe"/>
                            </SwipeItems>
                        </SwipeView.RightItems>

                        <!-- CARD -->
                        <Frame CornerRadius="15"
                               Padding="10"
                               Margin="5"
                               BackgroundColor="White">

                            <VerticalStackLayout Spacing="5">

                                <Label Text="{Binding Title}"
                                       FontSize="18"
                                       FontAttributes="Bold"/>

                                <Label Text="{Binding Category}"
                                       TextColor="Blue"/>

                                <Label Text="{Binding Amount, StringFormat='₹ {0}'}"
                                       TextColor="Green"/>

                                <Label Text="{Binding Date}"
                                       FontSize="12"
                                       TextColor="Gray"/>

                                <!-- EDIT -->
                                <Button Text="Edit"
                                        BackgroundColor="Orange"
                                        TextColor="White"
                                        CommandParameter="{Binding .}"
                                        Clicked="OnEditClicked"/>

                            </VerticalStackLayout>

                        </Frame>

                    </SwipeView>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </VerticalStackLayout>

</ContentPage>