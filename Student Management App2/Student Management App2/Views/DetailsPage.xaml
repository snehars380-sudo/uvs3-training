<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:StudentApp.ViewModels"
             x:Class="StudentApp.Views.DetailsPage">

    <ContentPage.BindingContext>
        <vm:StudentViewModel/>
    </ContentPage.BindingContext>

    <CollectionView ItemsSource="{Binding Students}">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Frame Margin="10">
                    <VerticalStackLayout>
                        <Label Text="{Binding Name}" FontAttributes="Bold"/>
                        <Label Text="{Binding Mark1, StringFormat='Mark1: {0}'}"/>
                        <Label Text="{Binding Mark2, StringFormat='Mark2: {0}'}"/>
                        <Label Text="{Binding Mark3, StringFormat='Mark3: {0}'}"/>
                    </VerticalStackLayout>
                </Frame>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>

</ContentPage>