<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyExpenseTracker.MainPage">

    <VerticalStackLayout Padding="20" Spacing="10">

        <Label Text="Expense Tracker" 
               FontSize="24"
               HorizontalOptions="Center"/>

        <Entry x:Name="titleEntry" Placeholder="Title"/>
        <Entry x:Name="amountEntry" Placeholder="Amount" Keyboard="Numeric"/>

        <Button Text="Add Expense" Clicked="OnAddClicked"/>

        <CollectionView x:Name="expenseList">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="5" Padding="10">
                        <VerticalStackLayout>
                            <Label Text="{Binding Title}" FontSize="18"/>
                            <Label Text="{Binding Amount}"/>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>

</ContentPage>